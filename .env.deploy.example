# Copy to .env.deploy and fill in.
# .env.deploy is gitignored (matches .env* pattern).

# Target host (FQDN or IP)
DEPLOY_HOST=portflow.uk

# Deploy user on the remote (NOT root)
DEPLOY_USER=deploy

# SSH port (defaults to 22 if omitted)
DEPLOY_PORT=22

# Project root on the remote
DEPLOY_PROJECT_DIR=/opt/projects/portflow

# Optional: explicit SSH private key path. If omitted, ssh uses your agent / default key.
# Examples:
#   DEPLOY_KEY=~/.ssh/id_ed25519
#   DEPLOY_KEY=~/.ssh/portflow_deploy
# DEPLOY_KEY=
