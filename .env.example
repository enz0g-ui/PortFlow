# ===== Required =====
AISSTREAM_API_KEY=replace-with-your-aisstream-key
PORT_API_TOKENS=replace-with-secret-token-1,another-token-for-second-client

# ===== Auth (Clerk) — required for multi-user / billing =====
# CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ===== Billing (Stripe) =====
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# ===== Error tracking (Sentry) =====
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ===== Production DB swap (optional) =====
# DATABASE_URL=postgres://user:pass@host:5432/portflow

# ===== Logging =====
# LOG_FORMAT=json   # plain by default, json for production aggregation
# LOG_LEVEL=info    # set to "debug" for verbose

# ===== Rate limit =====
# API_RATE_LIMIT=300   # default 300 req/min/token, override globally

# ===== SAR / Sentinel-1 (free public Copernicus account) =====
# COPERNICUS_CLIENT_ID=
# COPERNICUS_CLIENT_SECRET=
# SAR_DEMO=0   # set to 1 to seed synthetic detections without Copernicus

# ===== Paid satellite providers (optional) =====
# SPIRE_API_TOKEN=
# MARINETRAFFIC_API_KEY=
# ORBCOMM_API_TOKEN=
# EOG_LICENSE_KEY=    # VIIRS Boat Detection — Payne Institute commercial license
